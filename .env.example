# ========================================
# AIKO INSIGHTS PORTAL - ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ========================================
# GOOGLE DRIVE CONFIGURATION
# ========================================
# OAuth 2.0 Credentials from Google Cloud Console
GOOGLE_DRIVE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=GOCSPX-your-client-secret

# Google Drive Folder IDs
GOOGLE_DRIVE_POWERBI_FOLDER_ID=your-powerbi-reports-folder-id
GOOGLE_DRIVE_DOCUMENTATION_FOLDER_ID=your-documentation-folder-id
GOOGLE_DRIVE_SKILLS_FOLDER_ID=your-skills-folder-id
GOOGLE_DRIVE_SCRIPTS_FOLDER_ID=your-scripts-folder-id
GOOGLE_DRIVE_TEMP_FOLDER_ID=your-temp-folder-id

# Google Drive Redirect URI (must match OAuth console)
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ========================================
# SUPABASE CONFIGURATION
# ========================================
# Get these from Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-database-password

# ========================================
# ANTHROPIC API CONFIGURATION
# ========================================
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-api-key

# Model Configuration
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# ========================================
# APPLICATION CONFIGURATION
# ========================================
# Environment: development, production, test
NODE_ENV=development

# Server Configuration
PORT=3001
FRONTEND_URL=http://localhost:3000

# API Base URLs
API_BASE_URL=http://localhost:3001/api

# ========================================
# SECURITY CONFIGURATION
# ========================================
# Session Secret (generate a random 32-character string)
# Use: openssl rand -base64 32
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# JWT Secret for token signing
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# CORS Origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000,https://aiko.datadictum.com

# ========================================
# RATE LIMITING
# ========================================
# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# ========================================
# FILE STORAGE CONFIGURATION
# ========================================
# Local temp directory for PBIX processing
TEMP_DIR=./temp

# Max file size for uploads (in bytes) - 500MB default
MAX_FILE_SIZE=524288000

# ========================================
# LOGGING CONFIGURATION
# ========================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log directory
LOG_DIR=./logs

# ========================================
# SYNC CONFIGURATION
# ========================================
# Auto-sync interval (in minutes)
SYNC_INTERVAL_MINUTES=60

# Enable/disable auto-sync on startup
SYNC_ON_STARTUP=true

# ========================================
# CHAT CONFIGURATION
# ========================================
# Maximum chat history to load (number of messages)
MAX_CHAT_HISTORY=50

# Chat session timeout (in minutes)
CHAT_SESSION_TIMEOUT=30

# ========================================
# POWER BI MCP SERVER CONFIGURATION
# ========================================
# MCP Server connection settings
MCP_SERVER_TIMEOUT=30000
MCP_MAX_RETRIES=3

# ========================================
# FEATURE FLAGS
# ========================================
# Enable/disable features
ENABLE_TEXT_TO_SPEECH=true
ENABLE_AUTO_METADATA_REFRESH=true
ENABLE_WEB_SEARCH=false

# ========================================
# DEPLOYMENT CONFIGURATION (Production)
# ========================================
# Uncomment and configure for production deployment

# DOMAIN=aiko.datadictum.com
# FRONTEND_URL=https://aiko.datadictum.com
# API_BASE_URL=https://aiko.datadictum.com/api
# NODE_ENV=production
# GOOGLE_DRIVE_REDIRECT_URI=https://aiko.datadictum.com/auth/google/callback
